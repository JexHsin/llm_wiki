# Web-equivalent migration environment example
#
# The transitional public API proxy listens on 0.0.0.0:${LLM_WIKI_WEB_PORT:-19830}
# and forwards to the original local API server on 127.0.0.1:19828.

LLM_WIKI_WEB_PORT=19830

# Browser-side API base. Use the server IP when accessing from another node.
# Example: http://192.168.1.10:19830
VITE_LLM_WIKI_API_BASE=http://127.0.0.1:19830

# Optional API token. Keep this aligned with the original llm_wiki API config.
# VITE_LLM_WIKI_API_TOKEN=
